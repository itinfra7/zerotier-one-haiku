+static bool ___getLinkLayerAddress(const std::string& dev, MAC& mac)
+{
+#ifdef __HAIKU__
+	std::string cmd("ifconfig ");
+	cmd.append(dev);
+	FILE* fp = ::popen(cmd.c_str(), "r");
+	if (! fp) {
+		return false;
+	}
+
+	bool found = false;
+	char line[512];
+	while (::fgets(line, sizeof(line), fp)) {
+		const char* marker = strstr(line, "Address: ");
+		if (! marker) {
+			continue;
+		}
+
+		unsigned int b[6];
+		if (::sscanf(marker + 9, "%x:%x:%x:%x:%x:%x", &b[0], &b[1], &b[2], &b[3], &b[4], &b[5]) == 6) {
+			uint8_t raw[6];
+			for (unsigned int i = 0; i < 6; ++i) {
+				raw[i] = (uint8_t)b[i];
+			}
+			mac.setTo(raw, 6);
+			found = true;
+			break;
+		}
+	}
+
+	::pclose(fp);
+	return found;
+#else
+	struct ifaddrs* ifa = (struct ifaddrs*)0;
+	if (getifaddrs(&ifa) != 0) {
+		return false;
+	}
+
+	bool found = false;
+	for (struct ifaddrs* p = ifa; p; p = p->ifa_next) {
