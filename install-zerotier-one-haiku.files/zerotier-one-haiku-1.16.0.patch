+static MAC ___haikuZeroTierMacFromIdentityPath(const char* path, uint64_t nwid)
+{
+	if ((! path) || (! path[0])) {
+		return MAC();
+	}
+
+	std::string identity;
+	if ((! OSUtils::readFile(path, identity)) || identity.empty()) {
+		fprintf(stderr, "HAIKU TAP IDENTITY path=%s result=read-failed" ZT_EOL_S, path);
+		fflush(stderr);
+		return MAC();
+	}
+
+	while ((! identity.empty()) && ((identity[identity.length() - 1] == '\n') || (identity[identity.length() - 1] == '\r'))) {
+		identity.erase(identity.length() - 1);
+	}
+
+	Identity parsedIdentity;
+	if (parsedIdentity.fromString(identity.c_str())) {
+		MAC derived(parsedIdentity.address(), nwid);
+		char macBuf[18];
+		char addrBuf[11];
+		fprintf(stderr, "HAIKU TAP IDENTITY path=%s result=parsed addr=%s nwid=%.16llx mac=%s" ZT_EOL_S, path, parsedIdentity.address().toString(addrBuf), (unsigned long long)nwid, derived.toString(macBuf));
+		fflush(stderr);
+		return derived;
+	}
+
+	const char* sep = strchr(identity.c_str(), ':');
+	if (sep && ((sep - identity.c_str()) >= 10)) {
+		char addrHex[11];
+		memcpy(addrHex, identity.data(), 10);
+		addrHex[10] = 0;
+		MAC derived(Address(Utils::hexStrToU64(addrHex)), nwid);
+		char macBuf[18];
+		fprintf(stderr, "HAIKU TAP IDENTITY path=%s result=manual addr=%s nwid=%.16llx mac=%s" ZT_EOL_S, path, addrHex, (unsigned long long)nwid, derived.toString(macBuf));
+		fflush(stderr);
+		return derived;
+	}
+
+	fprintf(stderr, "HAIKU TAP IDENTITY path=%s result=parse-failed raw-prefix=%.10s" ZT_EOL_S, path, identity.c_str());
+	fflush(stderr);
+	return MAC();
+}
+
+static MAC ___haikuZeroTierMacFromIdentity(const char* homePath, uint64_t nwid)
+{
+	std::string identityPublicPath;
+	const char* candidatePaths[3] = {
+		"",
+		"/boot/system/non-packaged/var/lib/zerotier-one/identity.public",
+		"/boot/home/config/settings/zerotier-one/identity.public",
+	};
+
+	if (homePath && homePath[0]) {
+		identityPublicPath.assign(homePath);
+		identityPublicPath.append(ZT_PATH_SEPARATOR_S "identity.public");
+		candidatePaths[0] = identityPublicPath.c_str();
+	}
+
+	for (unsigned int i = 0; i < (sizeof(candidatePaths) / sizeof(candidatePaths[0])); ++i) {
+		MAC derived(___haikuZeroTierMacFromIdentityPath(candidatePaths[i], nwid));
+		if (derived) {
+			return derived;
+		}
+	}
+
+	return MAC();
+}
