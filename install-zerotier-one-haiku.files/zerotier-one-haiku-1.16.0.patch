+static inline bool ___inetAddressEqualsRaw(const InetAddress& ip, const void* raw, unsigned int len)
+{
+	return (ip && ((ip.isV4() && (len == 4)) || (ip.isV6() && (len == 16))) && (! memcmp(ip.rawIpData(), raw, len)));
+}
+
+static inline MAC ___ipv4MulticastToMac(const uint8_t* ip)
+{
+	uint8_t mac[6] = { 0x01, 0x00, 0x5e, (uint8_t)(ip[1] & 0x7f), ip[2], ip[3] };
+	return MAC(mac, 6);
+}
+
+static inline MAC ___ipv6MulticastToMac(const uint8_t* ip)
+{
+	uint8_t mac[6] = { 0x33, 0x33, ip[12], ip[13], ip[14], ip[15] };
+	return MAC(mac, 6);
+}
+
+static inline const char* ___haikuIpv4ToString(uint32_t ip, char buf[INET_ADDRSTRLEN])
+{
+	if (! inet_ntop(AF_INET, &ip, buf, INET_ADDRSTRLEN)) {
+		OSUtils::ztsnprintf(buf, INET_ADDRSTRLEN, "0.0.0.0");
+	}
+	return buf;
+}
+
+static inline const char* ___haikuRawIpv4ToString(const uint8_t* ip, char buf[INET_ADDRSTRLEN])
+{
+	if (! ip || ! inet_ntop(AF_INET, ip, buf, INET_ADDRSTRLEN)) {
+		OSUtils::ztsnprintf(buf, INET_ADDRSTRLEN, "0.0.0.0");
+	}
+	return buf;
+}
+
+static inline uint16_t ___checksum(const void* data, unsigned int len)
+{
+	const uint8_t* p = reinterpret_cast<const uint8_t*>(data);
+	uint32_t sum = 0;
+	while (len > 1) {
+		sum += (uint32_t)((p[0] << 8) | p[1]);
+		p += 2;
+		len -= 2;
+	}
+	if (len) {
+		sum += (uint32_t)(p[0] << 8);
+	}
+	while (sum >> 16) {
+		sum = (sum & 0xffff) + (sum >> 16);
+	}
+	return (uint16_t)(~sum);
+}
+
+static inline uint16_t ___icmpv6Checksum(const uint8_t* src, const uint8_t* dst, const uint8_t* payload, unsigned int payloadLen)
+{
+	if (payloadLen > 256) {
+		return 0;
+	}
+	uint8_t pseudo[40 + 256];
+	memset(pseudo, 0, sizeof(pseudo));
+	memcpy(pseudo, src, 16);
+	memcpy(pseudo + 16, dst, 16);
+	pseudo[35] = (uint8_t)(payloadLen & 0xff);
+	pseudo[34] = (uint8_t)((payloadLen >> 8) & 0xff);
+	pseudo[39] = 58;
+	memcpy(pseudo + 40, payload, payloadLen);
+	return ___checksum(pseudo, 40 + payloadLen);
+}
+
+static bool ___haikuFindMatchingLocalV6(const std::vector<InetAddress>& localIps, const uint8_t* targetIp, InetAddress& found)
+{
+	for (std::vector<InetAddress>::const_iterator i(localIps.begin()); i != localIps.end(); ++i) {
+		if (i->isV6() && ___inetAddressEqualsRaw(*i, targetIp, 16)) {
+			found = *i;
+			return true;
+		}
+	}
+	return false;
+}
+
+static MAC ___haikuOutgoingDestMac(unsigned int etherType, const uint8_t* packet, unsigned int len)
+{
+	if ((etherType == ZT_ETHERTYPE_IPV4) && (len >= 20)) {
+		const uint8_t* dst = packet + 16;
+		if (dst[0] >= 224 && dst[0] <= 239) {
+			return ___ipv4MulticastToMac(dst);
+		}
+		return ___broadcastMac;
+	}
+	if ((etherType == ZT_ETHERTYPE_IPV6) && (len >= 40)) {
+		const uint8_t* dst = packet + 24;
+		if (dst[0] == 0xff) {
+			return ___ipv6MulticastToMac(dst);
+		}
+		return ___broadcastMac;
+	}
+	return MAC();
+}
+
+static bool ___haikuBuildNeighborAdvertisement(const uint8_t* localIp, const uint8_t* remoteIp, const MAC& localMac, uint8_t* response, unsigned int& responseLen)
+{
+	if ((! localIp) || (! remoteIp) || (! response)) {
+		responseLen = 0;
+		return false;
+	}
+
+	uint8_t* ipv6 = response;
+	memset(ipv6, 0, 72);
+	ipv6[0] = 0x60;
+	ipv6[5] = 32;
+	ipv6[6] = 58;
+	ipv6[7] = 255;
+	memcpy(ipv6 + 8, localIp, 16);
+	memcpy(ipv6 + 24, remoteIp, 16);
+
+	uint8_t* na = ipv6 + 40;
+	na[0] = 136;
+	na[4] = 0x60; // solicited + override
+	memcpy(na + 8, localIp, 16);
+	na[24] = 2;
+	na[25] = 1;
+	localMac.copyTo(na + 26, 6);
+
+	const uint16_t checksum = ___icmpv6Checksum(localIp, remoteIp, na, 32);
+	na[2] = (uint8_t)(checksum >> 8);
+	na[3] = (uint8_t)(checksum & 0xff);
+	responseLen = 72;
+	return true;
+}
+
+static void ___haikuRewriteArpPayloadMacs(uint8_t* packet, unsigned int len, const MAC& fromMac, const MAC& toMac)
+{
+	if ((! packet) || (len < 28) || (! fromMac) || (! toMac)) {
+		return;
+	}
+
+	if ((packet[0] != 0x00) || (packet[1] != 0x01) || (packet[2] != 0x08) || (packet[3] != 0x00) || (packet[4] != 0x06) || (packet[5] != 0x04)) {
+		return;
+	}
+
+	if (MAC(packet + 8, 6) == fromMac) {
+		toMac.copyTo(packet + 8, 6);
+	}
+	if (MAC(packet + 18, 6) == fromMac) {
+		toMac.copyTo(packet + 18, 6);
+	}
+}
+
+static void ___haikuRewriteNdPayloadMacs(uint8_t* packet, unsigned int len, const MAC& fromMac, const MAC& toMac)
+{
+	if ((! packet) || (len < 40) || (! fromMac) || (! toMac) || ((packet[0] >> 4) != 6) || (packet[6] != 58)) {
+		return;
+	}
+
+	const unsigned int payloadLen = (((unsigned int)packet[4]) << 8) | packet[5];
+	if ((payloadLen < 8) || ((40 + payloadLen) > len)) {
+		return;
+	}
+
+	uint8_t* icmpv6 = packet + 40;
+	const unsigned int icmpv6Len = payloadLen;
+	unsigned int optionsOffset = 0;
+	bool rewritten = false;
+
+	switch (icmpv6[0]) {
+		case 133:
+			optionsOffset = 8;
+			break;
+		case 134:
+			optionsOffset = 16;
+			break;
+		case 135:
+		case 136:
+			optionsOffset = 24;
+			break;
+		case 137:
+			optionsOffset = 40;
+			break;
+		default:
+			return;
+	}
+
+	while ((optionsOffset + 2) <= icmpv6Len) {
+		uint8_t* option = icmpv6 + optionsOffset;
+		const unsigned int optionLen = ((unsigned int)option[1]) * 8;
+		if ((optionLen < 8) || ((optionsOffset + optionLen) > icmpv6Len)) {
+			break;
+		}
+		if (((option[0] == 1) || (option[0] == 2)) && (optionLen >= 8) && (MAC(option + 2, 6) == fromMac)) {
+			toMac.copyTo(option + 2, 6);
+			rewritten = true;
+		}
+		optionsOffset += optionLen;
+	}
+
+	if (rewritten) {
+		const uint8_t* srcIp = packet + 8;
+		const uint8_t* dstIp = packet + 24;
+		icmpv6[2] = 0;
+		icmpv6[3] = 0;
+		const uint16_t checksum = ___icmpv6Checksum(srcIp, dstIp, icmpv6, icmpv6Len);
+		icmpv6[2] = (uint8_t)(checksum >> 8);
+		icmpv6[3] = (uint8_t)(checksum & 0xff);
+	}
+}
+
+static inline bool ___haikuIsArpRequest(const uint8_t* packet, unsigned int len)
+{
+	return (packet && (len >= 28) && (packet[0] == 0x00) && (packet[1] == 0x01) && (packet[2] == 0x08) && (packet[3] == 0x00) && (packet[4] == 0x06) && (packet[5] == 0x04) && (packet[6] == 0x00) && (packet[7] == 0x01));
+}
+
+static inline bool ___haikuIsArpResponse(const uint8_t* packet, unsigned int len)
+{
+	return (packet && (len >= 28) && (packet[0] == 0x00) && (packet[1] == 0x01) && (packet[2] == 0x08) && (packet[3] == 0x00) && (packet[4] == 0x06) && (packet[5] == 0x04) && (packet[6] == 0x00) && (packet[7] == 0x02));
+}
